{
  "refreshInterval": 300,
  "updateToken": "change-this-update-token",
  "proxy": "http://127.0.0.1:7897",
  "alert": {
    "threshold": 100,
    "email": "your-email@example.com",
    "smtp_host": "smtp.example.com",
    "smtp_port": 465,
    "smtp_user": "your-smtp-user@example.com",
    "smtp_password": "your-smtp-password"
  },
  "sites": [
    {
      "name": "示例站点",
      "type": "newapi",
      "baseUrl": "https://api.example.com",
      "headerKey": "New-Api-User",
      "accounts": [
        {
          "name": "account1",
          "account": "user1@example.com",
          "userId": "123456",
          "accessToken": "your-access-token"
        }
      ]
    },
    {
      "name": "人民币站点",
      "type": "newapi",
      "baseUrl": "https://api.example.cn",
      "headerKey": "X-Api-User",
      "rate": 7.2,
      "accounts": [
        {
          "name": "account2",
          "account": "user2@example.com",
          "userId": "654321",
          "accessToken": "your-access-token"
        }
      ]
    },
    {
      "name": "OpenCode",
      "type": "opencode",
      "serverId": "your-server-id",
      "accounts": [
        {
          "name": "account1",
          "workspaceId": "wrk_xxxxxxxxxxxxxxxx",
          "authCookie": "your-auth-cookie"
        }
      ]
    },
    {
      "name": "火山方舟",
      "type": "volcengine",
      "accounts": [
        {
          "name": "手机号或用户名",
          "cookies": "从浏览器控制台复制的完整 Cookie 字符串",
          "csrfToken": "从浏览器请求头中获取的 CSRF Token",
          "webId": "从浏览器请求头中获取的 Web ID"
        }
      ]
    },
    {
      "name": "联通云",
      "type": "cucloud",
      "accounts": [
        {
          "name": "账号ID",
          "token": "从浏览器请求头中获取的 Bearer Token",
          "accountId": "联通云账号ID",
          "tenantId": "联通云租户ID",
          "signature": "从浏览器请求 URL 中获取的签名参数"
        }
      ]
    }
  ]
}
